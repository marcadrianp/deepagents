# Deep Agents Web App - Environment Variables

# Python Backend Configuration
# The URL where the Deep Agents Python backend is running
# Default: http://localhost:8000 (for local development)
DEEP_AGENT_BACKEND_URL=http://localhost:8000

# Anthropic API Key (required for the Python backend)
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: LangChain API Key for tracing (if using LangChain+)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
